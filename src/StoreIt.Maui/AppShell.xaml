<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StoreIt.Maui.AppShell"
    xmlns:local="clr-namespace:StoreIt.Maui"
    xmlns:views="clr-namespace:StoreIt.Maui.Views"
    xmlns:navigation="clr-namespace:StoreIt.Navigation;assembly=StoreIt.Maui"
    Title="StoreIt"
    FlyoutBehavior="Disabled">

    <!--  Main Tab  -->
    <TabBar>
        <ShellContent
            Title="Mijn Items"
            ContentTemplate="{DataTemplate views:MainPage}"
            Icon="cards"
            Route="{x:Static navigation:Pages.MainPage}" />
        <ShellContent
            Title="Instellingen"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Icon="settings"
            Route="{x:Static navigation:Pages.SettingsPage}" />
    </TabBar>

</Shell>
