<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StoreIt.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StoreIt.Maui"
    xmlns:views="clr-namespace:StoreIt.Maui.Views"
    Title="StoreIt"
    FlyoutBehavior="Disabled">

    <!--  Main Tab  -->
    <TabBar>
        <ShellContent
            Title="Mijn Kaarten"
            ContentTemplate="{DataTemplate views:MainPage}"
            Icon="cards"
            Route="main" />
        <ShellContent
            Title="Instellingen"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Icon="settings"
            Route="settings" />
    </TabBar>

</Shell>
