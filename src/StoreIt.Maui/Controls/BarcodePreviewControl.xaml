<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="StoreIt.Maui.Controls.BarcodePreviewControl"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:StoreIt.Maui.Controls"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    x:Name="Root"
    x:DataType="controls:BarcodePreviewControl"
    InputTransparent="True">
    <VerticalStackLayout Spacing="5">
        <Border
            Padding="15"
            BackgroundColor="{AppThemeBinding Light=#F0F8FF,
                                              Dark=#1E2A3A}"
            Stroke="{AppThemeBinding Light=#ADD8E6,
                                     Dark=#4682B4}"
            StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="8">
                <!--  Barcode Visual Preview  -->
                <Border
                    Padding="10"
                    BackgroundColor="White"
                    HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4" />
                    </Border.StrokeShape>
                    <zxing:BarcodeGeneratorView
                        x:Name="previewBarcodeGenerator"
                        BackgroundColor="White"
                        ForegroundColor="Black"
                        HeightRequest="80"
                        WidthRequest="200" />
                </Border>

                <!--  Preview Text  -->
                <Label
                    x:Name="barcodePreviewText"
                    FontFamily="Monospace"
                    FontSize="14"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Light=#2E5D8A,
                                                Dark=#87CEEB}" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentView>
