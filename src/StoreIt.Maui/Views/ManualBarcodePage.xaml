<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StoreIt.Maui.Views.ManualBarcodePage"
    xmlns:controls="clr-namespace:StoreIt.Maui.Controls"
    xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    Title="Barcode Invoeren"
    x:DataType="vm:ManualBarcodeViewModel"
    Shell.PresentationMode="ModalAnimated">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!--  Header  -->
            <Grid ColumnDefinitions="50,*,50">
                <!--  Back Button  -->
                <Button
                    Grid.Column="0"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource BackButtonStyle}" />

                <!--  Title  -->
                <Label
                    Grid.Column="1"
                    Style="{StaticResource PageTitleStyle}"
                    Text="Barcode handmatig invoeren" />
            </Grid>

            <!--  Instructions  -->
            <!-- <Border BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1E3A5F}"
                    Stroke="{AppThemeBinding Light=#2196F3, Dark=#64B5F6}"
                    StrokeThickness="1"
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="ℹ️ Barcode handmatig invoeren"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"/>
                    <Label Text="Kies het barcode type en voer het nummer exact in zoals het op je kaart staat."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"/>
                </VerticalStackLayout>
            </Border>-->

            <!--  Barcode Type Selection  -->
            <VerticalStackLayout Spacing="8">
                <Label Style="{StaticResource InputLabelStyle}" Text="Barcode Type" />
                <Picker
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5,
                                                      Dark=#2D2D2D}"
                    FontSize="16"
                    ItemsSource="{Binding AvailableBarcodeTypes}"
                    SelectedItem="{Binding SelectedBarcodeType}" />
                <Label Style="{StaticResource InputLabelSubStyle}" Text="Veelvoorkomende types: Code128, EAN13, QR_CODE" />
            </VerticalStackLayout>

            <!--  Barcode Number Input  -->
            <VerticalStackLayout Spacing="8">
                <Label Style="{StaticResource InputLabelStyle}" Text="Barcode Nummer" />
                <Entry
                    MaxLength="250"
                    Placeholder="Voer het barcode nummer in..."
                    Style="{StaticResource CodeInputEntryStyle}"
                    Text="{Binding BarcodeInput}" />
                <Label Style="{StaticResource InputLabelSubStyle}" Text="Voer het barcode nummer exact in zoals het op de kaart staat." />
            </VerticalStackLayout>

            <controls:BarcodePreviewControl
                Margin="0,0,0,10"
                BarcodeData="{Binding BarcodeInput}"
                BarcodeFormat="{Binding SelectedBarcodeType}"
                IsVisible="{Binding ShowBarcodePreview}"
                ShowValidation="True" />

            <!--  Action Buttons  -->
            <Grid
                Margin="0,20,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="15">
                <Button
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource VeryLightGray},
                                                      Dark={StaticResource Gray600}}"
                    Command="{Binding CancelCommand}"
                    HeightRequest="50"
                    Text="Annuleren"
                    TextColor="{AppThemeBinding Light=#666,
                                                Dark=#AAA}" />

                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource Secondary}"
                    Command="{Binding AcceptCommand}"
                    HeightRequest="50"
                    IsEnabled="{Binding CanAccept}"
                    Text="Toevoegen"
                    TextColor="White" />
            </Grid>

            <!--  Quick Access to Scan  -->
            <Border
                Margin="0,10,0,0"
                Padding="15"
                BackgroundColor="{AppThemeBinding Light=#FFF3E0,
                                                  Dark=#2D1B0E}"
                Stroke="{AppThemeBinding Light=#FF9800,
                                         Dark=#FFB74D}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label
                        Grid.Column="0"
                        FontSize="20"
                        Text="📷"
                        VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0">
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="Liever scannen?"
                            TextColor="{AppThemeBinding Light=#E65100,
                                                        Dark=#FFB74D}" />
                        <Label
                            FontSize="12"
                            Text="Gebruik de camera om automatisch te scannen"
                            TextColor="{AppThemeBinding Light=#E65100,
                                                        Dark=#FFB74D}" />
                    </VerticalStackLayout>
                    <Button
                        Grid.Column="2"
                        BackgroundColor="#FF9800"
                        Command="{Binding SwitchToScanCommand}"
                        HeightRequest="40"
                        Text="Scannen"
                        TextColor="White" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
