<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
      x:Class="StoreIt.Maui.Views.ScanBarcodePage"
      xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
      xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
      Title="Barcode Scannen"
      x:DataType="vm:ScanBarcodeViewModel"
      BackgroundColor="Black"
      Shell.PresentationMode="ModalAnimated">
      <ContentPage.Resources>
            <Style x:Key="CornerIndicatorStyle" TargetType="Path">
                  <Setter Property="Stroke" Value="{StaticResource Secondary}" />
                  <Setter Property="StrokeThickness" Value="4" />
            </Style>
      </ContentPage.Resources>

      <Grid RowDefinitions="Auto,*,Auto">
            <!--  Header  -->
            <Grid
                  Grid.Row="0"
                  Padding="15,10"
                  ColumnDefinitions="Auto,*, Auto">

                  <!--  Back Button  -->
                  <Button
                        Grid.Column="0"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ControlButtonStyle}"
                        Text="✕"
                        TextColor="White" />

                  <!--  Title  -->
                  <Label
                        Grid.Column="1"
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="Scan je barcode"
                        TextColor="White"
                        VerticalOptions="Center" />
            </Grid>

            <!--  Camera View  -->
            <zxing:CameraBarcodeReaderView
                  x:Name="cameraView"
                  Grid.Row="1"
                  BarcodesDetected="OnBarcodesDetected"
                  CameraLocation="Rear"
                  IsDetecting="{Binding IsScanning}" />

            <!--  Scanning Overlay  -->
            <Grid
                  Grid.Row="1"
                  InputTransparent="True"
                  IsVisible="{Binding IsScanning}">

                  <!--  Scanning Frame  -->
                  <Border
                        BackgroundColor="Transparent"
                        HeightRequest="140"
                        HorizontalOptions="Center"
                        Stroke="White"
                        StrokeThickness="2"
                        VerticalOptions="Center"
                        WidthRequest="280">
                        <Border.StrokeShape>
                              <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                  </Border>

                  <!--  Corner indicators  -->
                  <Grid
                        HeightRequest="140"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="280">
                        <!--  Top Left  -->
                        <Path
                              Data="M 0,20 L 0,0 L 20,0"
                              HorizontalOptions="Start"
                              Style="{StaticResource CornerIndicatorStyle}"
                              VerticalOptions="Start" />

                        <!--  Top Right  -->
                        <Path
                              Data="M 0,0 L 20,0 L 20,20"
                              HorizontalOptions="End"
                              Style="{StaticResource CornerIndicatorStyle}"
                              VerticalOptions="Start" />

                        <!--  Bottom Left  -->
                        <Path
                              Data="M 0,0 L 0,20 L 20,20"
                              HorizontalOptions="Start"
                              Style="{StaticResource CornerIndicatorStyle}"
                              VerticalOptions="End" />

                        <!--  Bottom Right  -->
                        <Path
                              Data="M 0,20 L 20,20 L 20,0"
                              HorizontalOptions="End"
                              Style="{StaticResource CornerIndicatorStyle}"
                              VerticalOptions="End" />
                  </Grid>

                  <!--  Instructions  -->
                  <Label
                        Margin="20,0,20,100"
                        Padding="15,10"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="Houd de barcode binnen het kader"
                        TextColor="White"
                        VerticalOptions="End" />
            </Grid>

            <!--  Footer  -->
            <Grid
                  Grid.Row="2"
                  Padding="15,10"
                  BackgroundColor="#80000000"
                  IsVisible="{Binding IsScanning}">

                  <Button
                        BackgroundColor="{StaticResource Secondary}"
                        Command="{Binding SwitchToManualCommand}"
                        HeightRequest="50"
                        Text="Handmatig invoeren"
                        TextColor="White" />
            </Grid>
      </Grid>
</ContentPage>
