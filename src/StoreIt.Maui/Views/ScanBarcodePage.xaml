<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StoreIt.Maui.Views.ScanBarcodePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
             x:DataType="vm:ScanBarcodeViewModel"
             Title="Barcode Scannen"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="Black">
             <ContentPage.Resources>
                <Style TargetType="Path" x:Key="CornerIndicatorStyle">
                    <Setter Property="Stroke" Value="{StaticResource Secondary}"/>
                    <Setter Property="StrokeThickness" Value="4"/>
                </Style>
            </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" 
              Padding="15,10" ColumnDefinitions="Auto,*, Auto">

            <!-- Back Button -->
            <Button Grid.Column="0"
                    Style="{StaticResource ControlButtonStyle}"
                    Text="✕"
                    TextColor="White"
                    Command="{Binding CancelCommand}"/>

            <!-- Title -->
            <Label Grid.Column="1"
                   Text="Scan je klantenkaart"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- Camera View -->
        <zxing:CameraBarcodeReaderView Grid.Row="1"
                                       x:Name="cameraView"
                                       IsDetecting="{Binding IsScanning}"
                                       BarcodesDetected="OnBarcodesDetected"
                                       CameraLocation="Rear"/>

        <!-- Scanning Overlay -->
        <Grid Grid.Row="1" 
              IsVisible="{Binding IsScanning}"
              InputTransparent="True">
            
            <!-- Scanning Frame -->
            <Border WidthRequest="280"
                    HeightRequest="140"
                    Stroke="White"
                    StrokeThickness="2"
                    BackgroundColor="Transparent"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
            </Border>

            <!-- Corner indicators -->
            <Grid WidthRequest="280" HeightRequest="140"
                  HorizontalOptions="Center" VerticalOptions="Center">
                <!-- Top Left -->
                <Path Data="M 0,20 L 0,0 L 20,0"
                      Style="{StaticResource CornerIndicatorStyle}"
                      HorizontalOptions="Start" VerticalOptions="Start"/>
                
                <!-- Top Right -->
                <Path Data="M 0,0 L 20,0 L 20,20"
                      Style="{StaticResource CornerIndicatorStyle}"
                      HorizontalOptions="End" VerticalOptions="Start"/>
                
                <!-- Bottom Left -->
                <Path Data="M 0,0 L 0,20 L 20,20"
                      Style="{StaticResource CornerIndicatorStyle}"
                      HorizontalOptions="Start" VerticalOptions="End"/>
                
                <!-- Bottom Right -->
                <Path Data="M 0,20 L 20,20 L 20,0"
                      Style="{StaticResource CornerIndicatorStyle}"
                      HorizontalOptions="End" VerticalOptions="End"/>
            </Grid>

            <!-- Instructions -->
            <Label Text="Houd de barcode binnen het kader"
                   FontSize="16"
                   TextColor="White"
                   Padding="15,10"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="20,0,20,100"/>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" 
              BackgroundColor="#80000000" 
              Padding="15,10"
              IsVisible="{Binding IsScanning}">
            
            <Button Text="Handmatig invoeren"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="White"
                    HeightRequest="50"
                    Command="{Binding SwitchToManualCommand}"/>
        </Grid>
    </Grid>
</ContentPage>
