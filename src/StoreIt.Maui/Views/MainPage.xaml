<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StoreIt.Maui.Views.MainPage"
    xmlns:local="clr-namespace:StoreIt.Maui.Views"
    xmlns:models="clr-namespace:StoreIt.Maui.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
    x:Name="mainPage"
    Title="Mijn Kaarten"
    x:DataType="vm:MainViewModel">
    <ContentPage.Resources>
        <Style x:Key="MessageLabelStyle" TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=Gray, Dark=LightGray}" />
        </Style>
        <Style
            x:Key="CardBorderWithShadowStyle"
            BasedOn="{StaticResource CardBorderStyle}"
            TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource VeryLightGray}, Dark={StaticResource Gray600}}" />
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow
                        Brush="{AppThemeBinding Light=Black,
                                                Dark=Transparent}"
                        Opacity="0.1"
                        Radius="8"
                        Offset="0,2" />
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>
    <Grid Margin="0, 0, 0, -100" VerticalOptions="Fill" HorizontalOptions="Fill">
        <CollectionView
            BackgroundColor="transparent"
            ItemSizingStrategy="MeasureAllItems"
            ItemsSource="{Binding Cards}"
            VerticalOptions="Fill">
            <CollectionView.Footer>
                <Grid HeightRequest="150" BackgroundColor="transparent" />
            </CollectionView.Footer>
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Spacing="20"
                    VerticalOptions="Center">
                    <Label
                        FontSize="60"
                        HorizontalOptions="Center"
                        Text="👋" />

                    <Label
                        FontSize="18"
                        HorizontalOptions="Center"
                        Style="{StaticResource MessageLabelStyle}"
                        Text="Geen klantenkaarten gevonden" />

                    <Label
                        FontSize="14"
                        HorizontalOptions="Center"
                        Style="{StaticResource MessageLabelStyle}"
                        Text="Tik op de + knop om je eerste kaart toe te voegen" />

                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CustomerCard">
                    <ContentView
                        x:Name="element"
                        Margin="10, 5"
                        Padding="0"
                        BackgroundColor="transparent">
                        <Border Margin="10,5" Style="{StaticResource CardBorderWithShadowStyle}">
                            <Grid
                                Padding="0"
                                ColumnDefinitions="8,*,Auto,Auto"
                                RowDefinitions="Auto, Auto">

                                <!--  Color Strip  -->
                                <BoxView
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    Margin="0,0,0,-10"
                                    BackgroundColor="{Binding Color}"
                                    WidthRequest="8" />

                                <!--  Card Content  -->
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Padding="15,12"
                                    Spacing="4">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="{Binding Name}"
                                        TextColor="{AppThemeBinding Light=Black,
                                                                    Dark=White}" />

                                    <Label
                                        FontSize="14"
                                        IsVisible="{Binding Description, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                                        Text="{Binding Description}"
                                        TextColor="{AppThemeBinding Light=Gray,
                                                                    Dark=LightGray}" />
                                </VerticalStackLayout>

                                <!--  Favorite Button  -->
                                <Label
                                    Grid.Column="3"
                                    Padding="8"
                                    BackgroundColor="transparent"
                                    FontSize="18"
                                    HeightRequest="40"
                                    SemanticProperties.Description="Toggle favoriet"
                                    SemanticProperties.Hint="Tap om favoriet te maken of te verwijderen"
                                    Text="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                    TextColor="{Binding IsFavorite, Converter={StaticResource BoolToColorConverter}}"
                                    WidthRequest="40">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding ViewModel.ToggleFavoriteCommand, Source={x:Reference mainPage}, x:DataType=local:MainPage}"
                                                CommandParameter="{Binding .}"
                                                Tapped="TapGestureRecognizer_Tapped" />
                                        </Label.GestureRecognizers>
                                </Label>

                            

                                <!--  Last Used  -->
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="15,0,15,12"
                                    FontSize="11"
                                    Text="{Binding LastUsed, StringFormat='Laatst gebruikt: {0:dd MMM yyyy}'}"
                                    TextColor="{AppThemeBinding Light=#999,
                                                                Dark=#777}" />
                                <!--  Tap Gesture  -->
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding ViewModel.ViewCardCommand, Source={x:Reference mainPage}, x:DataType=local:MainPage}"
                                        CommandParameter="{Binding .}"
                                        Tapped="TapGestureRecognizer_Tapped" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Border>
                    </ContentView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!--  Floating Action Button  -->
        <Button 
            Margin="0, 0, 25, 110"
            Command="{Binding AddCardCommand}"
            HorizontalOptions="End"
            Style="{StaticResource RoundFloatingActionButton}"
            Text="+"
            VerticalOptions="End" />

        <!--  Loading Indicator  -->
        <Grid Margin="0, 0, 0, 100"
            BackgroundColor="{Binding BackgroundColor, Source={x:Reference mainPage}, x:DataType=local:MainPage}"
            HorizontalOptions="Fill"
            IsVisible="{Binding IsLoading}"
            VerticalOptions="Fill">
            <ActivityIndicator
                HeightRequest="25"
                HorizontalOptions="Center"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
