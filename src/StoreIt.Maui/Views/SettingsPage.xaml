<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StoreIt.Maui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:appmodel="clr-namespace:Microsoft.Maui.ApplicationModel;assembly=Microsoft.Maui.Essentials"
    xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
    xmlns:services="clr-namespace:StoreIt.Maui.Services"
    xmlns:local="clr-namespace:StoreIt.Maui.Views"
    Title="Instellingen"
    x:Name="root"
    x:DataType="vm:SettingsViewModel">
    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#FFF}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SectionTextStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="4, 0" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#AAA}" />
        </Style>
        <Style x:Key="PageDescriptionStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#666, Dark=#AAA}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="25">            
            <!--  Header  -->
            <VerticalStackLayout Spacing="5">
                <Label Style="{StaticResource PageDescriptionStyle}" Text="Pas de app aan naar jouw voorkeur" />
            </VerticalStackLayout>

            <!--  Theme Section  -->
            <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Style="{StaticResource SectionHeaderStyle}" Text="🎨 Thema" />
                        <Label Style="{StaticResource SectionTextStyle}" Text="Kies het uiterlijk van de app" />
                    </VerticalStackLayout>

                    <!--  Theme Options  -->
                    <VerticalStackLayout Spacing="10">
                        <!--  System/Device Theme  -->
                        <Border
                            BackgroundColor="{Binding IsSystemTheme, Converter={StaticResource BoolToThemeBackgroundConverter}}"
                            Stroke="{Binding IsSystemTheme, Converter={StaticResource BoolToThemeBorderConverter}}"
                            Style="{StaticResource SelectionContainerStyle}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label
                                    Grid.Column="0"
                                    FontSize="20"
                                    Text="📱"
                                    VerticalOptions="Center" />

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="Apparaat volgen"
                                        TextColor="{Binding IsSystemTheme, Converter={StaticResource BoolToThemeTextColorConverter}}" />
                                    <Label
                                        FontSize="12"
                                        Text="Gebruikt de systeeminstelling"
                                        TextColor="{AppThemeBinding Light=#666,
                                                                    Dark=#AAA}" />
                                </VerticalStackLayout>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ThemeSelectedCommand}" 
                                     CommandParameter="{x:Static services:ThemeOption.System}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!--  Light Theme  -->
                        <Border
                            BackgroundColor="{Binding IsLightTheme, Converter={StaticResource BoolToThemeBackgroundConverter}}"
                            Stroke="{Binding IsLightTheme, Converter={StaticResource BoolToThemeBorderConverter}}"
                            Style="{StaticResource SelectionContainerStyle}">

                            <Grid ColumnDefinitions="Auto,*">
                                <Label
                                    Grid.Column="0"
                                    FontSize="20"
                                    Text="☀️"
                                    VerticalOptions="Center" />

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="Licht thema"
                                        TextColor="{Binding IsLightTheme, Converter={StaticResource BoolToThemeTextColorConverter}}" />
                                    <Label
                                        FontSize="12"
                                        Text="Lichte achtergrond met donkere tekst"
                                        TextColor="{AppThemeBinding Light=#666,
                                                                    Dark=#AAA}" />
                                </VerticalStackLayout>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ThemeSelectedCommand}" 
                                     CommandParameter="{x:Static services:ThemeOption.Light}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!--  Dark Theme  -->
                        <Border
                            BackgroundColor="{Binding IsDarkTheme, Converter={StaticResource BoolToThemeBackgroundConverter}}"
                            Stroke="{Binding IsDarkTheme, Converter={StaticResource BoolToThemeBorderConverter}}"
                            Style="{StaticResource SelectionContainerStyle}">

                            <Grid ColumnDefinitions="Auto,*">
                                <Label
                                    Grid.Column="0"
                                    FontSize="20"
                                    Text="🌙"
                                    VerticalOptions="Center" />

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="Donker thema"
                                        TextColor="{Binding IsDarkTheme, Converter={StaticResource BoolToThemeTextColorConverter}}" />
                                    <Label
                                        FontSize="12"
                                        Text="Donkere achtergrond met lichte tekst"
                                        TextColor="{AppThemeBinding Light=#666,
                                                                    Dark=#AAA}" />
                                </VerticalStackLayout>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ThemeSelectedCommand}" 
                                     CommandParameter="{x:Static services:ThemeOption.Dark}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Hints Section  -->
            <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <!-- <VerticalStackLayout Spacing="15"> -->
                <VerticalStackLayout Spacing="5">
                    <Label Style="{StaticResource SectionHeaderStyle}" Text="💡 Hints" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label
                            Style="{StaticResource SectionTextStyle}"
                            Text="Schakel dit uit om geen hints meer te zien"
                            VerticalOptions="Center" />
                        <Switch
                            Grid.Column="1"
                            HorizontalOptions="End"
                            IsToggled="{Binding HintsEnabled}"
                            VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
                <!-- </VerticalStackLayout> -->
            </Border>

            <!--  Future Settings Sections  -->
            <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10" InputTransparent="True">
                    <Label Style="{StaticResource SectionHeaderStyle}" Text="ℹ️ Over de app" />
                    <HorizontalStackLayout Spacing="0">
                        <Label Style="{StaticResource SectionTextStyle}" Text="{x:Static appmodel:AppInfo.Name}" />
                        <Label Style="{StaticResource SectionTextStyle}" Text=" v" Margin="0"/>
                        <Label Style="{StaticResource SectionTextStyle}" Text="{x:Static appmodel:AppInfo.VersionString}" Margin="0"/>
                    </HorizontalStackLayout>

                    <!--  Spacer  -->
                    <BoxView BackgroundColor="Transparent" HeightRequest="10" />

                    <!--  Built with love message  -->
                    <Label
                        FontAttributes="Italic"
                        FontSize="12"
                        HorizontalTextAlignment="Center"
                        Text="Built with ❤️ in Belgium"
                        TextColor="{AppThemeBinding Light=#999,
                                                    Dark=#777}" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenWhatsNewCommand}" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
