<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StoreIt.Maui.Views.AddCardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:StoreIt.Maui.Controls"
    xmlns:local="clr-namespace:StoreIt.Maui.Views"
    xmlns:models="clr-namespace:StoreIt.Maui.Models"
    xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    x:Name="ThisPage"
    Title="{Binding Title}"
    x:DataType="vm:AddCardViewModel"
    Shell.PresentationMode="ModalAnimated">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <!--  Header  -->
                <Label Style="{StaticResource PageTitleStyle}" Text="{Binding SubTitle}" />

                <!--  Form Fields  -->
                <VerticalStackLayout Spacing="20">

                    <!--  Name Field  -->
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource InputLabelStyle}" Text="Naam van de kaart *" />
                        <Entry
                            MaxLength="50"
                            Placeholder="Bijv. Mijn Albert Heijn kaart"
                            Style="{StaticResource InputEntryStyle}"
                            Text="{Binding Name}" />
                    </VerticalStackLayout>

                    <!--  Description Field  -->
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource InputLabelStyle}" Text="Beschrijving (optioneel)" />
                        <Entry
                            MaxLength="75"
                            Placeholder="Bijv. Hoofdkaart gezin"
                            Style="{StaticResource InputEntryStyle}"
                            Text="{Binding Description}" />
                    </VerticalStackLayout>

                    <!--  Color Selection  -->
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource InputLabelStyle}" Text="Kies een kleur *" />

                        <CollectionView
                            ItemsSource="{Binding AvailableColors}"
                            SelectionMode="None"
                            VerticalOptions="Start">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout
                                    HorizontalItemSpacing="10"
                                    Orientation="Vertical"
                                    Span="4"
                                    VerticalItemSpacing="10" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:CardColor">
                                    <ContentView>
                                        <Border
                                            BackgroundColor="{Binding Value}"
                                            HeightRequest="60"
                                            HorizontalOptions="Center"
                                            Stroke="{AppThemeBinding Light={StaticResource VeryLightGray},
                                                                     Dark=#555}"
                                            StrokeThickness="3"
                                            WidthRequest="60">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="30" />
                                            </Border.StrokeShape>
                                            <Label
                                                FontSize="10"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                Text="{Binding Name}"
                                                TextColor="White"
                                                VerticalOptions="Center"
                                                VerticalTextAlignment="Center" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ViewModel.SelectColorCommand, Source={x:Reference ThisPage}, x:DataType=local:AddCardPage}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </ContentView>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!--  Selected Color Preview  -->
                        <HorizontalStackLayout Margin="0,10,0,0" Spacing="10">
                            <Label
                                FontSize="14"
                                Style="{StaticResource InputLabelSubStyle}"
                                Text="Geselecteerde kleur:"
                                VerticalOptions="Center" />
                            <Border
                                BackgroundColor="{Binding SelectedColor}"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                            </Border>
                            <Label
                                Style="{StaticResource InputLabelSubStyle}"
                                Text="{Binding SelectedColorObject.Name}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!--  Card Type Selection  -->
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource InputLabelStyle}" Text="Type kaart *" />

                        <Label
                            Margin="0,0,0,10"
                            Style="{StaticResource InputLabelSubStyle}"
                            Text="Kies wel type kaart je wilt toevoegen:" />

                        <!--  Option 1: Barcode  -->
                        <Border
                            Margin="0,5"
                            BackgroundColor="{Binding ShowBarcodeScanning, Converter={StaticResource BoolToCardTypeBackgroundConverter}}"
                            Stroke="{Binding ShowBarcodeScanning, Converter={StaticResource BoolToCardTypeBorderConverter}}"
                            Style="{StaticResource SelectionContainerStyle}">

                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!--  Icon  -->
                                <controls:IconControl
                                    Grid.Column="0"
                                    BorderSize="50"
                                    Icon="📱"
                                    IconBackgroundColor="#2196F3"
                                    IconSize="24" />

                                <!--  Text  -->
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="Kaart met barcode"
                                        TextColor="{Binding ShowBarcodeScanning, Converter={StaticResource BoolToCardTypeTextColorConverter}}" />
                                    <Label
                                        FontSize="12"
                                        Text="Scan of voer handmatig een barcode in"
                                        TextColor="{AppThemeBinding Light=#666,
                                                                    Dark=#AAA}" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectBarcodeOptionCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <!--  Barcode Section - Direct onder barcode optie  -->
                        <VerticalStackLayout
                            Margin="10,10,10,15"
                            IsVisible="{Binding ShowBarcodeScanning}"
                            Spacing="8">

                            <controls:BarcodePreviewControl
                                Margin="0,0,0,10"
                                BarcodeData="{Binding BarcodeData}"
                                BarcodeFormat="{Binding BarcodeFormat}"
                                IsVisible="{Binding ShowBarcodePreview}"
                                ShowValidation="False" />

                            <!--  Barcode Entry Options  -->
                            <Grid
                                Margin="0,10,0,0"
                                ColumnDefinitions="*,*"
                                ColumnSpacing="10">
                                <!--  Scan Button  -->
                                <Button
                                    Grid.Column="0"
                                    BackgroundColor="{Binding SelectedColor}"
                                    Command="{Binding OpenScanBarcodePageCommand}"
                                    CornerRadius="22"
                                    FontSize="14"
                                    HeightRequest="45"
                                    Text="📷 Scannen"
                                    TextColor="White" />

                                <!--  Manual Entry Button  -->
                                <Button
                                    Grid.Column="1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource VeryLightGray},
                                                                      Dark={StaticResource Gray600}}"
                                    Command="{Binding OpenManualBarcodePageCommand}"
                                    CornerRadius="22"
                                    FontSize="14"
                                    HeightRequest="45"
                                    Text="✏️ Handmatig"
                                    TextColor="{AppThemeBinding Light=#666,
                                                                Dark=#AAA}" />
                            </Grid>

                        </VerticalStackLayout>

                        <!--  Option 2: Custom Code  -->
                        <Border
                            Margin="0,5"
                            BackgroundColor="{Binding ShowCustomCodeInput, Converter={StaticResource BoolToCardTypeBackgroundConverter}}"
                            Stroke="{Binding ShowCustomCodeInput, Converter={StaticResource BoolToCardTypeBorderConverter}}"
                            Style="{StaticResource SelectionContainerStyle}">

                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!--  Icon  -->
                                <controls:IconControl
                                    Grid.Column="0"
                                    BorderSize="50"
                                    Icon="🔢"
                                    IconBackgroundColor="#FF9800"
                                    IconSize="24" />

                                <!--  Text  -->
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="Kaart met code"
                                        TextColor="{Binding ShowCustomCodeInput, Converter={StaticResource BoolToCardTypeTextColorConverter}}" />
                                    <Label Style="{StaticResource InputLabelSubStyle}" Text="Voer een nummer of code in" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCustomCodeOptionCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <!--  Custom Code Section - Direct onder code optie  -->
                        <VerticalStackLayout
                            Margin="10,10,10,15"
                            IsVisible="{Binding ShowCustomCodeInput}"
                            Spacing="8">

                            <Entry
                                BackgroundColor="{AppThemeBinding Light=#F5F5F5,
                                                                  Dark=#2D2D2D}"
                                Placeholder="Bijv. 123456789 of ABC-123-DEF"
                                MaxLength="150"
                                Style="{StaticResource CodeInputEntryStyle}"
                                Text="{Binding CustomCode}" />

                            <Label Style="{StaticResource InputLabelSubStyle}" Text="Voer je lidmaatschapsnummer, toegangscode of andere identificatie in." />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!--  Action Buttons  -->
                    <Grid
                        Margin="0,30,0,0"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="15">
                        <Button
                            Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource VeryLightGray},
                                                              Dark={StaticResource Gray600}}"
                            Command="{Binding CancelCommand}"
                            CornerRadius="25"
                            FontSize="16"
                            HeightRequest="50"
                            Text="Annuleren"
                            TextColor="{AppThemeBinding Light=#666,
                                                        Dark=#AAA}" />

                        <Button
                            Grid.Column="1"
                            BackgroundColor="{Binding SelectedColor}"
                            Command="{Binding SaveCardCommand}"
                            CornerRadius="25"
                            FontSize="16"
                            HeightRequest="50"
                            Text="{Binding SaveButtonText}"
                            TextColor="White" />
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        <controls:HintControl
            x:Name="SaveHint"
            Margin="20,0,20,20"
            HorizontalOptions="Center"
            Icon="💾"
            IsShowing="{Binding ShowSaveHint}"
            Text="Vergeet niet om op te slaan, onderaan de pagina!"
            VerticalOptions="End" />
    </Grid>
</ContentPage>
