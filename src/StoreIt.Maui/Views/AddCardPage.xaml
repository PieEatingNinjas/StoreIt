<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StoreIt.Maui.Views.AddCardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:vm="clr-namespace:StoreIt.Maui.ViewModels"
             xmlns:models="clr-namespace:StoreIt.Maui.Models"
             xmlns:local="clr-namespace:StoreIt.Maui.Views"
             xmlns:controls="clr-namespace:StoreIt.Maui.Controls"
             x:DataType="vm:AddCardViewModel"
             x:Name="ThisPage"
             Shell.PresentationMode="ModalAnimated"
             Title="{Binding Title}">
    <Grid>
        <ScrollView>
            <StackLayout Padding="20" Spacing="20">
                
                <!-- Header -->
                <Label Text="{Binding SubTitle}"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,10,0,20"/>

                <!-- Form Fields -->
            <StackLayout Spacing="20">
                
                <!-- Name Field -->
                <StackLayout Spacing="8">
                    <Label Text="Naam van de kaart *" 
                           Style="{StaticResource InputLabelStyle}" />
                    <Entry Text="{Binding Name}"
                           Placeholder="Bijv. Mijn Albert Heijn kaart"
                           Style="{StaticResource InputEntryStyle}" />
                </StackLayout>

                <!-- Description Field -->
                <StackLayout Spacing="8">
                    <Label Text="Beschrijving (optioneel)" 
                           Style="{StaticResource InputLabelStyle}" />
                    <Entry Text="{Binding Description}"
                           Placeholder="Bijv. Hoofdkaart gezin"
                           Style="{StaticResource InputEntryStyle}" />
                </StackLayout>

                <!-- Color Selection -->
                <StackLayout Spacing="8">
                    <Label Text="Kies een kleur *" 
                           Style="{StaticResource InputLabelStyle}"/>
                    
                    <CollectionView ItemsSource="{Binding AvailableColors}"
                                    SelectionMode="None"
                                    VerticalOptions="Start">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" 
                                             Span="4" 
                                             VerticalItemSpacing="10" 
                                             HorizontalItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CardColor">
                                <ContentView>
                                    <Border BackgroundColor="{Binding Value}"
                                            WidthRequest="60"
                                            HeightRequest="60"
                                            StrokeThickness="3"
                                            HorizontalOptions="Center"
                                            Stroke="{AppThemeBinding Light={StaticResource VeryLightGray}, Dark=#555}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="30"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Name}"
                                            FontSize="10"
                                            TextColor="White"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            VerticalTextAlignment="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ViewModel.SelectColorCommand, Source={x:Reference ThisPage}, x:DataType=local:AddCardPage}"
                                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    
                    <!-- Selected Color Preview -->
                    <StackLayout Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Label Text="Geselecteerde kleur:"
                               FontSize="14"
                               Style="{StaticResource InputLabelSubStyle}"
                               VerticalOptions="Center"/>
                        <Border BackgroundColor="{Binding SelectedColor}"
                                WidthRequest="30"
                                HeightRequest="30"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"/>
                            </Border.StrokeShape>
                        </Border>
                        <Label Text="{Binding SelectedColorObject.Name}"
                              Style="{StaticResource InputLabelSubStyle}" VerticalOptions="Center" />
                    </StackLayout>
                </StackLayout>

                <!-- Card Type Selection -->
                <StackLayout Spacing="8">
                    <Label Text="Type kaart *" 
                           Style="{StaticResource InputLabelStyle}" />
                    
                    <Label Text="Kies wel type kaart je wilt toevoegen:"
                           Style="{StaticResource InputLabelSubStyle}"
                           Margin="0,0,0,10"/>

                    <!-- Option 1: Barcode -->
                    <Border BackgroundColor="{Binding ShowBarcodeScanning, Converter={StaticResource BoolToCardTypeBackgroundConverter}}"
                            Stroke="{Binding ShowBarcodeScanning, Converter={StaticResource BoolToCardTypeBorderConverter}}"
                            StrokeThickness="2"
                            Padding="15"
                            Margin="0,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#2196F3"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="25"/>
                                </Border.StrokeShape>
                                <Label Text="📱"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="White"/>
                            </Border>

                            <!-- Text -->
                            <StackLayout Grid.Column="1" 
                                         Margin="15,0,0,0"
                                         VerticalOptions="Center">
                                <Label Text="Kaart met barcode"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{Binding ShowBarcodeScanning, Converter={StaticResource BoolToCardTypeTextColorConverter}}"/>
                                <Label Text="Scan of voer handmatig een barcode in"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"/>
                            </StackLayout>
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectBarcodeOptionCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Barcode Section - Direct onder barcode optie -->
                    <StackLayout Spacing="8" IsVisible="{Binding ShowBarcodeScanning}" Margin="10,10,10,15">

                        <controls:BarcodePreviewControl
                            Margin="0,0,0,10"
                            BarcodeData="{Binding BarcodeData}"
                            ShowValidation="False"
                            BarcodeFormat="{Binding BarcodeFormat}"
                            IsVisible="{Binding ShowBarcodePreview}"/>

                        <StackLayout Spacing="5" IsVisible="false">
                            <!-- <Label Text="Barcode Preview" 
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333, Dark=#CCC}"/> -->
                            <Border BackgroundColor="{AppThemeBinding Light=#F0F8FF, Dark=#1E2A3A}"
                                    Stroke="{AppThemeBinding Light=#ADD8E6, Dark=#4682B4}"
                                    StrokeThickness="1"
                                    Padding="15">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                
                                <VerticalStackLayout Spacing="8">
                                    <!-- Barcode Visual Preview -->
                                    <Border BackgroundColor="White"
                                            Padding="10"
                                            HorizontalOptions="Center"
                                            IsVisible="{Binding ShowBarcodePreview}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4"/>
                                        </Border.StrokeShape>
                                        <zxing:BarcodeGeneratorView x:Name="previewBarcodeGenerator"
                                                                    Value="{Binding BarcodeData}"
                                                                    Format="{Binding BarcodeFormat, Converter={StaticResource StringToBarcodeFormatConverter}}"
                                                                    WidthRequest="200"
                                                                    HeightRequest="80"
                                                                    ForegroundColor="Black"
                                                                    BackgroundColor="White"/>
                                    </Border>

                                     <!-- Preview Text -->
                                    <Label Text="{Binding BarcodePreviewText}"
                                           FontSize="14"
                                           FontFamily="Monospace"
                                           TextColor="{AppThemeBinding Light=#2E5D8A, Dark=#87CEEB}"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </StackLayout>

                        <!-- Barcode Entry Options -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                            <!-- Scan Button -->
                            <Button Grid.Column="0"
                                    Text="📷 Scannen"
                                    BackgroundColor="{Binding SelectedColor}"
                                    TextColor="White"
                                    HeightRequest="45"
                                    CornerRadius="22"
                                    FontSize="14"
                                    Command="{Binding OpenScanBarcodePageCommand}"/>
                            
                            <!-- Manual Entry Button -->
                            <Button Grid.Column="1"
                                    Text="✏️ Handmatig"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource VeryLightGray}, Dark={StaticResource Gray600}}"
                                    TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                                    HeightRequest="45"
                                    CornerRadius="22"
                                    FontSize="14"
                                    Command="{Binding OpenManualBarcodePageCommand}"/>
                        </Grid>

                        <!-- Barcode Preview Section -->
                        
                    </StackLayout>

                    <!-- Option 2: Custom Code -->
                    <Border BackgroundColor="{Binding ShowCustomCodeInput, Converter={StaticResource BoolToCardTypeBackgroundConverter}}"
                            Stroke="{Binding ShowCustomCodeInput, Converter={StaticResource BoolToCardTypeBorderConverter}}"
                            StrokeThickness="2"
                            Padding="15"
                            Margin="0,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#FF9800"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="25"/>
                                </Border.StrokeShape>
                                <Label Text="🔢"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="White"/>
                            </Border>

                            <!-- Text -->
                            <StackLayout Grid.Column="1" 
                                         Margin="15,0,0,0"
                                         VerticalOptions="Center">
                                <Label Text="Kaart met code"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{Binding ShowCustomCodeInput, Converter={StaticResource BoolToCardTypeTextColorConverter}}"/>
                                <Label Text="Voer een nummer of code in"
                                       Style="{StaticResource InputLabelSubStyle}"/>
                            </StackLayout>
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCustomCodeOptionCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Custom Code Section - Direct onder code optie -->
                    <StackLayout Spacing="8" IsVisible="{Binding ShowCustomCodeInput}" Margin="10,10,10,15">
                        <!-- <Label Text="Code / Lidmaatschapsnummer" 
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#333, Dark=#CCC}"/> -->
                        
                        <Entry Text="{Binding CustomCode}"
                               Placeholder="Bijv. 123456789 of ABC-123-DEF"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}"
                               Style="{StaticResource CodeInputEntryStyle}"/>
                        
                        <Label Text="Voer je lidmaatschapsnummer, toegangscode of andere identificatie in."
                               Style="{StaticResource InputLabelSubStyle}"/>
                    </StackLayout>
                </StackLayout>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,30,0,0">
                    <Button Grid.Column="0"
                            Text="Annuleren"
                            BackgroundColor="{AppThemeBinding Light={StaticResource VeryLightGray}, Dark={StaticResource Gray600}}"
                            TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                            HeightRequest="50"
                            CornerRadius="25"
                            FontSize="16"
                            Command="{Binding CancelCommand}"/>
                    
                    <Button Grid.Column="1"
                            Text="{Binding SaveButtonText}"
                            BackgroundColor="{Binding SelectedColor}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="25"
                            FontSize="16"
                            Command="{Binding SaveCardCommand}"/>
                </Grid>
            </StackLayout>
        </StackLayout>
    </ScrollView>
    <controls:HintControl Text="Vergeet niet om op te slaan, onderaan de pagina!"
                          Icon="💾"
                          x:Name="SaveHint"
                          IsShowing="{Binding ShowSaveHint}"
                          HorizontalOptions="Center"
                          VerticalOptions="End"
                          Margin="20,0,20,20"/>
    </Grid>
</ContentPage>
